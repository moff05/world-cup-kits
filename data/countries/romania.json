  "facts": [
    {
      "id": "the-tricolorii",
      "label": "BORN FROM THE FLAG",
      "story": "Romania's nickname, Tricolorii — the Tricolors — comes directly from wearing all three colors of the national flag at once: blue, yellow, and red. The yellow shirt only became the primary color in 1970, after decades of red dominating; the look crystallized at the 1990 World Cup in Italy, when Romania wore yellow shirts, blue shorts, and red socks, a combination fans still consider the definitive Tricolorii kit."
    },
    {
      "id": "the-bleach-bet",
      "label": "THE BLEACHED HAIR BET",
      "story": "Two days before the 1998 World Cup opener, Romania's players dared coach Anghel Iordănescu to shave his head if the team advanced through the group. He agreed — on the condition they'd dye their hair blond in return. After beating Colombia and England, all 23 players and their newly bald coach walked out against Tunisia as platinum blonds, a stunt still replayed on Romanian television every World Cup."
    }
  ],
