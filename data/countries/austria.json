  "facts": [
    {
      "id": "the-wunderteam",
      "label": "THE WUNDERTEAM ERA",
      "story": "Under coach Hugo Meisl and led by the balletic Matthias Sindelar — nicknamed 'Der Papierene,' the Paper Man, for his slight frame and delicate touch — Austria's national team went 14 games unbeaten between April 1931 and December 1932, thrashing Germany and Scotland along the way. The press dubbed them the Wunderteam, the Miracle Team, and they carried that reputation into the 1934 World Cup as one of the tournament favorites, only to fall to hosts Italy in the semi-final."
    },
    {
      "id": "red-becomes-home-2004",
      "label": "RED FINALLY TAKES OVER",
      "story": "For nearly a century, Austria's white shirt and black shorts traced back to the colors of the Teutonic Order, with the flag's red reserved for the away kit. That changed in 2004, when Austrian great Hans Krankl — the hero of Córdoba — pushed for red to become the primary color instead, arguing the national team should wear the flag's red-white-red on center stage rather than in the shadows."
    }
  ],
